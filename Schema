react usage 
export function ThemePackCard({ pack, onPreview }) {
  return (
    <article className="theme-card">
      <img src={pack.assets.previewImage} alt={pack.title} />
      <h3>{pack.title}</h3>
      <p>{pack.artist.name}</p>
      <p>{pack.artist.country}</p>
      <p>{pack.licensing.licenseType}</p>
      <p>{pack.attributionText}</p>
      <button onClick={() => onPreview(pack.id)}>Preview</button>
    </article>
  );
}

validation helper
export function isThemePackValid(pack) {
  return Boolean(
    pack?.id &&
    pack?.title &&
    pack?.artist?.name &&
    pack?.artist?.country &&
    pack?.approvals?.artistApproved === true &&
    pack?.approvals?.communityApproved === true &&
    pack?.approvals?.publicationApproved === true &&
    pack?.licensing?.icipRespect === true &&
    pack?.assets?.previewImage
  );
}


