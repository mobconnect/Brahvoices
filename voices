import textToSpeech from '@google-cloud/text-to-speech';
import fs from 'fs';
import path from 'path';
import { resolveVoice, VOICE_STATE } from './voiceModel.js';

const client = new textToSpeech.TextToSpeechClient();

export async function synthesizeToFile({
  text,
  assetId = 'au-default',
  context = {},
  outputFile = 'output/speech.mp3',
  speakingRate = 1.0,
  pitch = 0.0
}) {
  const asset = resolveVoice(assetId, context);

  if (asset.state !== VOICE_STATE.STANDARD_TTS) {
    throw new Error('This asset is not a Google TTS voice. Use your approved audio playback pipeline.');
  }

  const [response] = await client.synthesizeSpeech({
    input: { text },
    voice: {
      languageCode: asset.languageCode,
      name: asset.voiceName
    },
    audioConfig: {
      audioEncoding: 'MP3',
      speakingRate,
      pitch
    }
  });

  fs.mkdirSync(path.dirname(outputFile), { recursive: true });
  fs.writeFileSync(outputFile, response.audioContent, 'binary');
  return outputFile;
}
