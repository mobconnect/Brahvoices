// src/voiceModel.js
export const VOICE_STATE = {
  STANDARD_TTS: 'standard-tts',
  PUBLIC_ACCESS_APPROVED: 'public-access-approved',
  COMMUNITY_APPROVED_RESTRICTED: 'community-approved-restricted'
};

export const VOICE_REGISTRY = [
  {
    id: 'au-default',
    label: 'Australian English default',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Neural2-A',
    description: 'Google-supported Australian voice'
  },
  {
    id: 'au-polyglot-1',
    label: 'Australian English polyglot',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Polyglot-1',
    description: 'Google-supported polyglot Australian voice'
  },
  {
    id: 'archive-approved-1',
    label: 'Public-access approved archive audio',
    state: VOICE_STATE.PUBLIC_ACCESS_APPROVED,
    accessApproved: true,
    description: 'AIATSIS-approved or equivalent approved collection asset'
  },
  {
    id: 'community-voice-1',
    label: 'Community-approved restricted voice',
    state: VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED,
    description: 'Requires rights-holder and community approval'
  }
];

export function canUseVoice(asset, context = {}) {
  if (!asset) return false;

  if (asset.state === VOICE_STATE.STANDARD_TTS) return true;

  if (asset.state === VOICE_STATE.PUBLIC_ACCESS_APPROVED) {
    return asset.accessApproved === true;
  }

  if (asset.state === VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED) {
    return Boolean(
      context.fpic === true &&
      context.rightsHolderApproved === true &&
      context.communityApproved === true &&
      context.usageScope &&
      context.publicationApproved !== false
    );
  }

  return false;
}

export function resolveVoice(assetId, context = {}) {
  const asset = VOICE_REGISTRY.find(v => v.id === assetId);
  if (!asset) throw new Error(`Unknown voice asset: ${assetId}`);
  if (!canUseVoice(asset, context)) throw new Error(`Voice not approved for use: ${assetId}`);
  return asset;
}

export function explainVoice(asset) {
  if (!asset) return 'Unknown voice.';
  if (asset.state === VOICE_STATE.STANDARD_TTS) return `Use Google TTS voice ${asset.voiceName}.`;
  if (asset.state === VOICE_STATE.PUBLIC_ACCESS_APPROVED) return 'Use approved archive audio.';
  if (asset.state === VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED) return 'Use only after community and rights-holder approval.';
  return 'Unknown voice state.';
}
