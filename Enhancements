import React, { useMemo, useState } from 'react';
import WebAudioPlayer from './WebAudioPlayer.jsx';
import { filterPhrases } from '../enhancements/lessonFilters.js';

export default function WebLessonPlayer({ phrases, audioMap }) {
  const [search, setSearch] = useState('');
  const [category, setCategory] = useState('all');
  const filtered = useMemo(() => filterPhrases(phrases, search, category), [phrases, search, category]);
  const [selected, setSelected] = useState(filtered[0]?.id || '');
  const phrase = filtered.find(p => p.id === selected) || filtered[0];
  const src = phrase ? audioMap[phrase.id] : null;

  return (
    <div>
      <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Search phrases" />
      <select value={category} onChange={(e) => setCategory(e.target.value)}>
        <option value="all">All</option>
        <option value="starter">Starter</option>
        <option value="practice">Practice</option>
        <option value="restricted">Restricted</option>
      </select>

      <select value={selected} onChange={(e) => setSelected(e.target.value)}>
        {filtered.map(p => <option key={p.id} value={p.id}>{p.text}</option>)}
      </select>

      {src ? <WebAudioPlayer src={src} /> : <p>No audio available.</p>}
    </div>
  );
}
