export async function discoverVoices(languageCode = 'en-AU') {
  const url = new URL('https://texttospeech.googleapis.com/v1/voices');
  url.searchParams.set('languageCode', languageCode);

  const res = await fetch(url.toString());
  if (!res.ok) throw new Error('Failed to load voices');

  const data = await res.json();
  return (data.voices || []).map(v => ({
    name: v.name,
    languageCodes: v.languageCodes || [],
    sampleRate: v.naturalSampleRateHertz || null,
    gender: v.ssmlGender || null
  }));
}
export function filterPhrases(phrases, query = '', category = 'all') {
  const q = query.trim().toLowerCase();

  return phrases.filter(p => {
    const matchesQuery = !q || p.text.toLowerCase().includes(q);
    const matchesCategory = category === 'all' || p.category === category;
    return matchesQuery && matchesCategory;
  });
}
