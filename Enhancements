export function explainAccess(claims = {}, context = {}) {
  const authOk = claims.communityVoiceAccess === true;
  const culturalOk = Boolean(
    context.fpic === true &&
    context.rightsHolderApproved === true &&
    context.communityApproved === true &&
    context.usageScope
  );

  return {
    authOk,
    culturalOk,
    allowed: authOk && culturalOk
  };
}
