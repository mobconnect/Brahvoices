import React, { useEffect, useState } from 'react';

export default function NativeAudioPlayer({ player, url }) {
  const [playing, setPlaying] = useState(false);

  useEffect(() => {
    let mounted = true;
    async function init() {
      if (!player) return;
      await player.initPlayer({ url });
      if (mounted) setPlaying(false);
    }
    init();
    return () => { mounted = false; };
  }, [player, url]);

  return (
    <div>
      <button onPress={async () => { await player.play(); setPlaying(true); }}>
        {playing ? 'Playing' : 'Play'}
      </button>
      <button onPress={async () => { await player.pause(); setPlaying(false); }}>
        Pause
      </button>
    </div>
  );
}
