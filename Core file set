const KEY = 'bruhvoices-lesson-progress';

export function loadLessonProgress() {
  try {
    return JSON.parse(localStorage.getItem(KEY) || '{}');
  } catch {
    return {};
  }
}

export function saveLessonProgress(progress) {
  localStorage.setItem(KEY, JSON.stringify(progress));
}

export function markPhraseDone(phraseId) {
  const progress = loadLessonProgress();
  progress[phraseId] = { done: true, updatedAt: new Date().toISOString() };
  saveLessonProgress(progress);
  return progress;
}

