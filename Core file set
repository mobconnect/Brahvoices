src voice model.js
export const VOICE_STATE = {
  STANDARD_TTS: 'standard-tts',
  PUBLIC_ACCESS_APPROVED: 'public-access-approved',
  COMMUNITY_APPROVED_RESTRICTED: 'community-approved-restricted'
};

export const VOICE_REGISTRY = [
  {
    id: 'au-default',
    label: 'Australian English default',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Neural2-A'
  },
  {
    id: 'au-polyglot-1',
    label: 'Australian English polyglot',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Polyglot-1'
  },
  {
    id: 'archive-approved-1',
    label: 'Public-access approved archive audio',
    state: VOICE_STATE.PUBLIC_ACCESS_APPROVED,
    accessApproved: true
  },
  {
    id: 'community-voice-1',
    label: 'Community-approved restricted voice',
    state: VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED
  }
];

export function canUseVoice(asset, context = {}) {
  if (!asset) return false;
  if (asset.state === VOICE_STATE.STANDARD_TTS) return true;
  if (asset.state === VOICE_STATE.PUBLIC_ACCESS_APPROVED) return asset.accessApproved === true;
  if (asset.state === VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED) {
    return Boolean(
      context.communityVoiceAccess === true &&
      context.fpic === true &&
      context.rightsHolderApproved === true &&
      context.communityApproved === true &&
      context.usageScope
    );
  }
  return false;
}

export function resolveVoice(assetId, context = {}) {
  const asset = VOICE_REGISTRY.find(v => v.id === assetId);
  if (!asset) throw new Error(`Unknown voice asset: ${assetId}`);
  if (!canUseVoice(asset, context)) throw new Error(`Voice not approved for use: ${assetId}`);
  return asset;
}

src voice discovery.js
export async function discoverVoices(languageCode = 'en-AU') {
  const url = new URL('https://texttospeech.googleapis.com/v1/voices');
  url.searchParams.set('languageCode', languageCode);

  const res = await fetch(url.toString());
  if (!res.ok) throw new Error('Failed to load voices');

  const data = await res.json();
  return (data.voices || []).map(v => ({
    name: v.name,
    languageCodes: v.languageCodes || [],
    sampleRate: v.naturalSampleRateHertz || null,
    gender: v.ssmlGender || null
  }));
}

src voice picker.js
export function makeVoiceOptions(voices = []) {
  return voices.map(v => ({
    id: v.id || v.name,
    label: v.label || v.name,
    languageCode: v.languageCode || (v.languageCodes ? v.languageCodes[0] : null),
    voiceName: v.voiceName || v.name,
    state: v.state || 'standard-tts'
  }));
}

src/auth/claims.js
export async function hasCommunityVoiceAccess(user) {
  if (!user) return false;
  const token = await user.getIdTokenResult(true);
  return token.claims.communityVoiceAccess === true;
}

import { hasCommunityVoiceAccess } from './claims.js';

export async function canAccessRestrictedVoice(user, voiceContext = {}) {
  const allowedByAuth = await hasCommunityVoiceAccess(user);
  return Boolean(
    allowedByAuth &&
    voiceContext.fpic === true &&
    voiceContext.rightsHolderApproved === true &&
    voiceContext.communityApproved === true &&
    voiceContext.usageScope
  );
}

