  { id: 'community-voice-1', label: 'Community-approved restricted voice' }
];

export default function VoiceDemo() {
  const [voiceId, setVoiceId] = useState('au-default');

  return (
    <div>
      <VoiceSelector voices={voices} value={voiceId} onChange={setVoiceId} />
      {voiceId === 'community-voice-1' ? (
