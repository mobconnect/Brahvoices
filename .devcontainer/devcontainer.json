export const VOICE_STATE = {
  STANDARD_TTS: 'standard-tts',
  PUBLIC_ACCESS_APPROVED: 'public-access-approved',
  COMMUNITY_APPROVED_RESTRICTED: 'community-approved-restricted'
};

export const VOICE_REGISTRY = [
  {
    id: 'au-default',
    label: 'Australian English default',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Neural2-A'
  },
  {
    id: 'au-polyglot-1',
    label: 'Australian English polyglot',
    state: VOICE_STATE.STANDARD_TTS,
    languageCode: 'en-AU',
    voiceName: 'en-AU-Polyglot-1'
  },
  {
    id: 'archive-approved-1',
    label: 'Public-access approved archive audio',
    state: VOICE_STATE.PUBLIC_ACCESS_APPROVED,
    accessApproved: true
  },
  {
    id: 'community-voice-1',
    label: 'Community-approved restricted voice',
    state: VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED
  }
];

export function canUseVoice(asset, context = {}) {
  if (!asset) return false;
  if (asset.state === VOICE_STATE.STANDARD_TTS) return true;
  if (asset.state === VOICE_STATE.PUBLIC_ACCESS_APPROVED) return asset.accessApproved === true;
  if (asset.state === VOICE_STATE.COMMUNITY_APPROVED_RESTRICTED) {
    return Boolean(
      context.communityVoiceAccess === true &&
      context.fpic === true &&
      context.rightsHolderApproved === true &&
      context.communityApproved === true &&
      context.usageScope
    );
  }
  return false;
}

export function resolveVoice(assetId, context = {}) {
  const asset = VOICE_REGISTRY.find(v => v.id === assetId);
  if (!asset) throw new Error(`Unknown voice asset: ${assetId}`);
  if (!canUseVoice(asset, context)) throw new Error(`Voice not approved for use: ${assetId}`);
  return asset;
}
export function explainApproval(context = {}) {
  return {
    communityVoiceAccess: context.communityVoiceAccess === true,
    fpic: context.fpic === true,
    rightsHolderApproved: context.rightsHolderApproved === true,
    communityApproved: context.communityApproved === true,
    usageScope: Boolean(context.usageScope)
  };
}

export function isCommunityApproved(context = {}) {
  return Boolean(
    context.communityVoiceAccess === true &&
    context.fpic === true &&
    context.rightsHolderApproved === true &&
    context.communityApproved === true &&
    context.usageScope
  );
}
import textToSpeech from '@google-cloud/text-to-speech';
import fs from 'fs';
import path from 'path';
import { resolveVoice, VOICE_STATE } from './voiceModel.js';

const client = new textToSpeech.TextToSpeechClient();

export async function synthesizeToFile({
  text,
  assetId = 'au-default',
  context = {},
  outputFile = 'output/speech.mp3',
  speakingRate = 1.0,
  pitch = 0.0
}) {
  const asset = resolveVoice(assetId, context);

  if (asset.state !== VOICE_STATE.STANDARD_TTS) {
    throw new Error('This asset is not a Google TTS voice. Use your approved audio playback pipeline.');
  }

  const [response] = await client.synthesizeSpeech({
    input: { text },
    voice: { languageCode: asset.languageCode, name: asset.voiceName },
    audioConfig: { audioEncoding: 'MP3', speakingRate, pitch }
  });

  fs.mkdirSync(path.dirname(outputFile), { recursive: true });
  fs.writeFileSync(outputFile, response.audioContent, 'binary');
  return outputFile;
}
export async function fetchGoogleVoices() {
  const res = await fetch('https://texttospeech.googleapis.com/v1/voices');
  if (!res.ok) throw new Error('Unable to fetch voices');
  return await res.json();
}
