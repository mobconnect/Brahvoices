import { getAuth } from 'firebase/auth';

export function getCurrentUser() {
  return getAuth().currentUser;
}
export async function hasCommunityVoiceAccess(user) {
  if (!user) return false;
  const token = await user.getIdTokenResult(true);
  return token.claims.communityVoiceAccess === true;
}
import { hasCommunityVoiceAccess } from './claims.js';

export async function canAccessRestrictedVoice(user, voiceContext = {}) {
  const allowedByAuth = await hasCommunityVoiceAccess(user);
  return Boolean(
    allowedByAuth &&
    voiceContext.fpic === true &&
    voiceContext.rightsHolderApproved === true &&
    voiceContext.communityApproved === true &&
    voiceContext.usageScope
  );
}
import admin from 'firebase-admin';

admin.initializeApp();

export async function grantCommunityVoiceAccess(uid) {
  await admin.auth().setCustomUserClaims(uid, {
    communityVoiceAccess: true,
    restrictedVoiceRole: 'approved'
  });
}
import admin from 'firebase-admin';

admin.initializeApp();

export async function verifyRestrictedToken(req, res, next) {
  try {
    const token = req.headers.authorization?.replace('Bearer ', '');
    const decoded = await admin.auth().verifyIdToken(token);

    if (decoded.communityVoiceAccess !== true) {
      return res.status(403).json({ error: 'Restricted voice access denied' });
    }

    next();
  } catch {
    res.status(401).json({ error: 'Unauthorized' });
  }
}
import React, { useEffect, useState } from 'react';
import { getAuth } from 'firebase/auth';

export default function RestrictedVoiceGate({ children }) {
  const [allowed, setAllowed] = useState(false);

  useEffect(() => {
    async function check() {
      const auth = getAuth();
      const user = auth.currentUser;
      if (!user) return setAllowed(false);

      const tokenResult = await user.getIdTokenResult(true);
      setAllowed(tokenResult.claims.communityVoiceAccess === true);
    }
    check();
  }, []);

  if (!allowed) return <p>This voice requires community approval.</p>;
  return children;
}
