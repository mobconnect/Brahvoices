user choice example
import React, { useState, useEffect } from 'react';
import ThemePicker from './themes/ThemePicker.jsx';
import { THEMES } from './themes/themeManifest.js';
import { applyTheme } from './themes/applyTheme.js';

export default function ThemeSettings() {
  const [themeKey, setThemeKey] = useState(localStorage.getItem('bruhvoices-theme') || 'default');

  useEffect(() => {
    applyTheme(THEMES[themeKey]);
    localStorage.setItem('bruhvoices-theme', themeKey);
  }, [themeKey]);

  return (
    <section>
      <ThemePicker value={themeKey} onChange={setThemeKey} />
      <p>Users can choose a visual style that suits them.</p>
    </section>
  );
}
