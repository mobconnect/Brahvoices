theme choice logic
import React, { useState } from 'react';
import ThemePicker from './ThemePicker.jsx';
import { THEMES } from './themeRegistry.js';
import { applyTheme } from './applyTheme.js';

export default function ThemeSettings() {
  const [themeKey, setThemeKey] = useState('default');

  const handleChange = (key) => {
    setThemeKey(key);
    applyTheme(THEMES[key]);
    localStorage.setItem('bruhvoices-theme', key);
  };

  return (
    <div>
      <ThemePicker value={themeKey} onChange={handleChange} />
      <p>Users can choose a visual style that suits their learning and accessibility needs.</p>
    </div>
  );
}
