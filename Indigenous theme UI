src ssmlbuilder.js
export function escapeXml(text = '') {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}

export function buildSSML(text, profile) {
  const pause = `<break time="${profile.breakMs || 180}ms"/>`;
  const safe = escapeXml(text);
  const rate = `${Math.round((profile.speakingRate || 1) * 100)}%`;
  const pitch = `${profile.pitch || 0}st`;

  return `<speak><prosody rate="${rate}" pitch="${pitch}">${safe}${pause}</prosody></speak>`;
}

src voice style
export function getVoiceStyle(profileKey) {
  switch (profileKey) {
    case 'warmLesson':
      return {
        title: 'Warm lesson style',
        description: 'Gentle pacing for guided learning.',
        tone: 'calm'
      };
    case 'slowPractice':
      return {
        title: 'Slow practice style',
        description: 'Slower delivery for repetition and clarity.',
        tone: 'clear'
      };
    case 'communityApproved':
      return {
        title: 'Community-approved style',
        description: 'Only available for approved assets.',
        tone: 'restricted'
      };
    default:
      return {
        title: 'Standard Australian style',
        description: 'Neutral Australian narration.',
        tone: 'neutral'
      };
  }
}

import textToSpeech from '@google-cloud/text-to-speech';
import { buildSSML } from './ssmlBuilder.js';

const client = new textToSpeech.TextToSpeechClient();

export async function synthesizeAudio({
  text,
  profile,
  outputEncoding = 'MP3'
}) {
  if (!profile) throw new Error('Missing audio profile');
  if (profile.requiresApproval) {
    throw new Error('Community-approved audio requires approval metadata and a separate playback path.');
  }

  const request = {
    input: { ssml: buildSSML(text, profile) },
    voice: {
      languageCode: profile.languageCode,
      name: profile.voiceName || undefined
    },
    audioConfig: {
      audioEncoding: outputEncoding,
      speakingRate: profile.speakingRate,
      pitch: profile.pitch,
      effectsProfileId: profile.effectsProfileId || []
    }
  };

  const [response] = await client.synthesizeSpeech(request);
  return response.audioContent;
}

